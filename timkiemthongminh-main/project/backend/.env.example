# Copy file này thành .env và điền giá trị thật — KHÔNG commit file .env.

# Hugging Face (Settings -> Access Tokens, chỉ cần quyền "Read")
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
HF_EMBEDDING_MODEL=BAAI/bge-m3
# Model cross-encoder dùng để rerank top ứng viên (xem rerank_service.py)
HF_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Qdrant Cloud (cloud.qdrant.io -> tạo cluster -> Cluster URL + API Key)
# QDRANT_URL BẮT BUỘC bắt đầu bằng https:// (Qdrant Cloud luôn cấp dạng này).
QDRANT_URL=https://xxxxxxxx.cloud.qdrant.io
QDRANT_API_KEY=xxxxxxxxxxxxxxxxxxxxx
QDRANT_COLLECTION_NAME=news_articles

# Số chiều vector của model embedding (BAAI/bge-m3 = 1024). Dùng để tạo
# collection mới nếu chưa tồn tại — đổi model thì nhớ đổi số này.
QDRANT_VECTOR_SIZE=1024

# Retry khi kết nối Qdrant Cloud thất bại (tuỳ chọn, có giá trị mặc định)
QDRANT_CONNECT_MAX_RETRIES=5
QDRANT_CONNECT_RETRY_BACKOFF_SECONDS=2
QDRANT_CONNECT_TIMEOUT_SECONDS=10

# CORS: domain frontend production, phân cách bởi dấu phẩy
ALLOWED_ORIGINS=http://localhost:5173,https://ten-project-cua-ban.vercel.app

# --- Search Pipeline (tuỳ chọn, có giá trị mặc định) ---
# Số kết quả cuối cùng trả về (sau bước rerank, nếu có).
SEARCH_TOP_K=10
# Số ứng viên lấy từ Qdrant TRƯỚC khi rerank/cắt còn SEARCH_TOP_K.
SEARCH_CANDIDATE_K=30
# Ngưỡng điểm tối thiểu (cosine) để giữ lại kết quả — để trống = không lọc.
SEARCH_SCORE_THRESHOLD=

# --- Cache TTL trong RAM cho embedding của query (tuỳ chọn) ---
CACHE_TTL_SECONDS=1800
CACHE_MAXSIZE=512

# --- Logging & version (tuỳ chọn) ---
LOG_LEVEL=INFO
APP_VERSION=2.1.0
