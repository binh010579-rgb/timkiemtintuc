# Copy file này thành .env và điền giá trị thật — KHÔNG commit file .env.

# Postgres (Neon) — nguồn dữ liệu bài báo (title/content/summary/url...).
# Lấy connection string ở Neon Console -> Connection string.
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require

# Hugging Face (Settings -> Access Tokens, chỉ cần quyền "Read")
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
HF_EMBEDDING_MODEL=BAAI/bge-m3
HF_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

QDRANT_URL=https://xxxxxxxx.cloud.qdrant.io
QDRANT_API_KEY=xxxxxxxxxxxxxxxxxxxxx
QDRANT_COLLECTION_NAME=news_articles
QDRANT_VECTOR_SIZE=1024
QDRANT_CONNECT_MAX_RETRIES=5
QDRANT_CONNECT_RETRY_BACKOFF_SECONDS=2
QDRANT_CONNECT_TIMEOUT_SECONDS=10

ALLOWED_ORIGINS=http://localhost:5173,https://ten-project-cua-ban.vercel.app

SEARCH_TOP_K=10
SEARCH_CANDIDATE_K=30
SEARCH_SCORE_THRESHOLD=

CACHE_TTL_SECONDS=1800
CACHE_MAXSIZE=512

LOG_LEVEL=INFO
APP_VERSION=2.1.0
